{
  "name": "agentation-vue",
  "version": "0.2.3",
  "description": "Visual feedback tool for AI coding agents — Vue 2.7 & 3",
  "author": "Dorian Becker",
  "license": "PolyForm-Shield-1.0.0",
  "homepage": "https://github.com/Blaked84/agentation-vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blaked84/agentation-vue.git",
    "directory": "packages/agentation-vue"
  },
  "keywords": [
    "vue",
    "agentation",
    "annotation",
    "ai",
    "feedback",
    "vue-demi"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./style.css": "./dist/styles/agentation.css"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "prepack": "pnpm run build",
    "dev": "unbuild --stub",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^2.7.0 || ^3.3.0"
  },
  "dependencies": {
    "vue-demi": "^0.14.0"
  },
  "devDependencies": {
    "unbuild": "^3.0.0",
    "vue": "^3.5.0",
    "vue-sfc-transformer": "^0.1.17"
  }
}
